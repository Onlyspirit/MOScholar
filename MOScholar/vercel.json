{
  "version": 2,
  "builds": [
    {
      "src": "angular.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/MOScholar" }
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist/MOScholar",
  "framework": "angular",
  "routes": [
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
